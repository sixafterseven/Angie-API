rules_version = '2';

// Angie OS - Cloud Storage security rules.
//
// Access model
// ------------
// 1. Membership lives in the Firestore `users` collection (one active document
//    per approved employee, keyed by lowercase email). These rules cross-check
//    that collection with firestore.get, so Storage and Firestore share one
//    source of truth. Never a domain check.
//
// 2. Calvin writes the cleaned workbook using the Firebase Admin SDK, which
//    bypasses security rules entirely. Denying client writes to cleaned/
//    therefore cannot break the pipeline.
//
// Storage layout (do not change without a migration plan):
//   raw/{batchId}/{filename}      - the original upload, written by the browser
//   cleaned/{batchId}/{filename}  - Calvin's output, written by the Admin SDK
//
// Managing employees
// ------------------
// Add, deactivate, or remove an employee by editing their users document
// (see functions/src/scripts/bootstrap-users.ts). No rules redeploy is needed.

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true;
    }

    // True only when the caller has an active users document in Firestore.
    function isActiveEmployee() {
      return isSignedIn()
        && firestore.exists(
          /databases/(default)/documents/users/$(request.auth.token.email.lower()))
        && firestore.get(
          /databases/(default)/documents/users/$(request.auth.token.email.lower())).data.active == true;
    }

    // Raw uploads - the upload page writes the original workbook here and the
    // registerRawUpload trigger picks it up.
    //
    // Create is allowed but update and delete are not: Clara's contract is that
    // the original upload is never modified, so the browser must not be able to
    // overwrite or remove a source file after the pipeline has started reading
    // it.
    match /raw/{batchId}/{filename} {
      allow read: if isActiveEmployee();
      allow create: if isActiveEmployee();
      allow update, delete: if false;
    }

    // Cleaned workbooks - employees may download Calvin's output. Writes are
    // denied; only Calvin produces these, through the Admin SDK.
    match /cleaned/{batchId}/{filename} {
      allow read: if isActiveEmployee();
      allow write: if false;
    }

    // Every other path is denied to the client.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
