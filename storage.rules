rules_version = '2';

// Angie OS - Cloud Storage security rules.
//
// Authorization mirrors Firestore: membership + permissions live in the
// `users` collection, which these rules cross-check with firestore.get. Never a
// domain check; fails closed.
//
// Layout:
//   raw/{batchId}/{filename}                       - browser upload (pipeline)
//   cleaned/{batchId}/{filename}                   - Calvin's Admin-SDK output
//   knowledge/{category}/{subcategory}/{filename}  - knowledge source originals

service firebase.storage {
  match /b/{bucket}/o {

    function isSignedIn() {
      return request.auth != null
        && request.auth.token.email != null
        && request.auth.token.email_verified == true;
    }

    function userPath() {
      return /databases/(default)/documents/users/$(request.auth.token.email.lower());
    }

    function isActiveEmployee() {
      return isSignedIn()
        && firestore.exists(userPath())
        && firestore.get(userPath()).data.active == true;
    }

    function perm(name) {
      return isActiveEmployee()
        && firestore.get(userPath()).data.get('permissions', {}).get(name, false) == true;
    }

    // Raw uploads - create-only; the source file is never overwritten/removed.
    match /raw/{batchId}/{filename} {
      allow read: if isActiveEmployee();
      allow create: if isActiveEmployee();
      allow update, delete: if false;
    }

    // Cleaned workbooks - read-only; only Calvin writes via the Admin SDK.
    match /cleaned/{batchId}/{filename} {
      allow read: if isActiveEmployee();
      allow write: if false;
    }

    // Knowledge source originals - permission-gated (knowledgeRead to read,
    // knowledgeWrite to upload/replace).
    match /knowledge/{category}/{subcategory}/{filename} {
      allow read: if perm('knowledgeRead');
      allow write: if perm('knowledgeWrite');
    }

    // Everything else is denied to the client.
    match /{allPaths=**} {
      allow read, write: if false;
    }
  }
}
